# Electron 环境变量配置

# 应用配置
APP_NAME="Android Remote Control"
APP_VERSION="1.0.0"
APP_DESCRIPTION="专业的Android设备远程控制桌面应用程序"

# 开发配置
NODE_ENV=development
ELECTRON_DISABLE_SECURITY_WARNINGS=false

# 服务器配置
RENDERER_PORT=3000
API_BASE_URL=http://localhost:8000

# 构建配置
ELECTRON_BUILDER_COMPRESSION=maximum
ELECTRON_BUILDER_ASAR=true

# 调试配置
ELECTRON_ENABLE_LOGGING=true
ELECTRON_DEBUG_PROD=false

# 平台特定配置
# macOS
ELECTRON_MAC_CATEGORY=public.app-category.developer-tools
ELECTRON_MAC_BUNDLE_ID=com.androidremotecontrol.app

# Windows
ELECTRON_WIN_COMPANY_NAME="Android Remote Control"
ELECTRON_WIN_PRODUCT_NAME="Android Remote Control"

# Linux
ELECTRON_LINUX_CATEGORY=Development
ELECTRON_LINUX_MAINTAINER="support@androidremotecontrol.com"

# 功能开关
ENABLE_AUTO_UPDATE=true
ENABLE_SYSTEM_TRAY=true
ENABLE_HARDWARE_ACCELERATION=true
ENABLE_REMOTE_DEBUGGING=false

# 性能配置
MAX_CONCURRENT_SESSIONS=5
VIDEO_QUALITY=high
FRAME_RATE=30
BUFFER_SIZE=1048576

# 日志配置
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=10